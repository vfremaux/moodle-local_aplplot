

<!-- local_aplplot -->

<div id="timeline_{{htmlid}}" style="height:{{height}}px;width:{{width}}px;border: 1px solid #aaa">
</div>

<script type="text/javascript">
    var tl;
    function timeline_initialize_{{htmlid}}() {

       // create bands
       var eventSource = new Timeline.DefaultEventSource();
       var bandInfos = [
            Timeline.createBandInfo({
                 eventSource:    eventSource,
                 width:          \"70%\",
                 intervalUnit:   Timeline.DateTime.{$theblock->config->upperbandunit},
                 intervalPixels: 100
            }),

            {{#showlowerband}}
            Timeline.createBandInfo({
                 eventSource:    eventSource,
                 width:          "30%",
                 intervalUnit:   Timeline.DateTime.{{lowerbandunit}},
                 intervalPixels: 200
            })
            {{/showlowerband}}

        ];

        {{#showlowerband}}
        bandInfos[1].syncWith = 0;
        bandInfos[1].highlight = true;
        {{/showlowerband}}

        tl = Timeline.create(document.getElementById("timeline_{{htmlid}}"), bandInfos);
        Timeline.loadXML("{{{xmlurl}}}", function(xml, url) { eventSource.loadXML(xml, url); });
    }

    var resizeTimerID = null;
    function onResize() {
        if (resizeTimerID == null) {
            resizeTimerID = window.setTimeout(function() {
                resizeTimerID = null;
                tl.layout();
            }, 500);
        }
    }
</script>

<!-- /local_aplplot -->